# Pin file for the N64Recomp engine checkout.
#
# CMake's configure step asserts that n64recomp/ HEAD matches what's
# pinned here. To roll forward, edit this file.
#
# Two optional fields:
#   branch = <ref>   default origin/main, used when sha is unset
#   sha    = <sha>   exact pin, takes precedence over branch when set

# ── Pinned to mstan/N64Recomp dev ─────────────────────────────────
# Active development happens on the `dev` branch of mstan/N64Recomp.
# Each stable point gets pinned by SHA so PSR builds are reproducible.
# To roll forward to a newer engine commit: bump the sha below.
# To track the dev tip during active iteration: comment out the sha
# line and set `branch = dev` instead.
# ── Rolled to N64Recomp main (tcc overlay backend) ──────────────
# 0dc2a0a carries the in-process libtcc overlay JIT (replaces sljit)
#   and the tcc_recompiler.h that N64ModernRuntime main's overlay tier
#   requires. Canonical engine; GB Tower R/B/Y user-verified on this pin.
sha = 0dc2a0a8d7f00d8471ef54897fdd31cc4ced07cd
