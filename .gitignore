build/
build-*/
*.o
*.obj
*.exe
*.pdb
*.ilk
*.lib
*.exp
*.user

# Generated recompiler output (regen via N64Recomp)
generated/

# Ghidra project state (live DBs are machine-specific, large)
ghidra/**/*.lock
ghidra/**/*.lock~
ghidra/**/*.gpr.bak
ghidra/**/projects/
# Ghidra volatile DB / temp state — held open while Ghidra is running,
# changes constantly, and breaks `git checkout` on Windows because the
# OS won't unlink files Ghidra has open.
ghidra/**/~*.db/
ghidra/**/~index.bak
ghidra/**/~index.dat
ghidra/**/~journal.bak
ghidra/**/tmp*.ps

# Ares emulator build artifacts (submoduled at ares-emulator/)
ares-emulator/

# N64Recomp engine checkout (cloned by setup.bat/sh, not committed)
n64recomp/

# Editor / OS
.vs/
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# Logs and temp
*.log
_tmp_*
_baseline_*
_experimental_*
_*.png
_*.pid

# Ad-hoc debug/probe scaffolding under tools/ (the `_`-prefixed scratch
# scripts from investigations). Permanent, named tools are tracked; these
# one-offs are not. See tools/README.md.
tools/_*

# ROM data (don't redistribute)
*.z64
*.n64
*.v64
*.gb
*.gbc

# Save / dump
*.sav
*.srm
*.state
saves.txt
saves/
launcher.cfg
tools/_derive.stderr
tools/_splice.py

# Local-only artifacts (Ghidra project DB, debug drivers, caches, backups)
ghidra/*.rep/
tools/_drive_*.py
__pycache__/
*.bak
*.bak-*
# Build artifacts produced by tools/_decompress_*.py — regenerable from
# baserom.z64 + the script. The script is the source of truth.
tools/*_decompressed.bin
lib/

# Internal docs kept locally only — see the `internal` branch for
# the full snapshot of these files at the point they were untracked.
CLAUDE.md
TO_ADAPT_FROM_BATTLESHIP.md
